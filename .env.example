# --- Skynet Nexus environment ---
# Copy this file to .env for local dev. Do NOT commit .env.

# Port the server listens on locally. Railway ignores this (they inject PORT).
PORT=4180

# Session cookie signing secret. Generate a random 64-char hex string:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-to-a-random-64-char-hex-string

# --- Persistent storage (IMPORTANT for production) ---
# Container filesystems on Railway are EPHEMERAL: without a Volume, every deploy
# wipes the user database AND any newly published articles. To keep users and the
# article archive for real, attach a Railway Volume to the service, then the app
# auto-detects RAILWAY_VOLUME_MOUNT_PATH and stores both the SQLite DB and the
# article data under it (seeding the bundled starter content on first boot).
#
# In Railway: Service -> Settings -> Volumes -> add a Volume, mount path e.g. /data
# Nothing else is required — the app reads RAILWAY_VOLUME_MOUNT_PATH automatically.
#
# Manual overrides (optional, for other hosts or local testing):
#   PERSIST_DIR=/data            # volume root; DB -> /data/skynet.db, data -> /data/data
#   DB_PATH=/data/skynet.db      # exact SQLite path (wins over PERSIST_DIR)
#   DATA_DIR=/data/data          # exact article/manifest dir (wins over PERSIST_DIR)
# PERSIST_DIR=/data

# NODE_ENV=production toggles secure cookies + longer static cache.
# Railway sets this automatically. Leave it unset locally.
# NODE_ENV=production

# Brave Search API key — used by newsroom correspondents.
# Free tier: https://api-dashboard.search.brave.com
BRAVE_API_KEY=your-brave-api-key

# --- Transactional email (password resets) ---
# Resend HTTP API — no SMTP/library needed. Free tier: https://resend.com
# Without RESEND_API_KEY, reset links are logged to the server console instead
# of emailed (fine for local dev; wire this before a public launch).
#   RESEND_API_KEY=re_xxxxxxxx
#   MAIL_FROM=Skynet Nexus <noreply@yourdomain.com>   # must be a verified sender
# RESEND_API_KEY=
# MAIL_FROM=Skynet Nexus <onboarding@resend.dev>

# --- Admin account seed (OPT-IN, idempotent on every boot) ---
# Seeding is optional. If you leave BOTH ADMIN_SEED_EMAIL and ADMIN_SEED_PASSWORD
# unset, the site boots with zero admins and the public first-time setup flow
# (/pages/register.html -> creates the owner admin, then auto-disables) is the
# single source of truth. Prefer that flow for a clean launch.
#
# If you DO set a seed: on startup the server ensures this user exists with
# role='admin'. There is NO hardcoded default password — if ADMIN_SEED_PASSWORD
# is unset but ADMIN_SEED_EMAIL is set and the account must be created, a strong
# random password is generated and printed to the logs ONCE. The seed password is
# only (re)applied while the account has never been logged into.
# ADMIN_SEED_EMAIL=owner@yourdomain.com
# ADMIN_SEED_PASSWORD=change-me-min-8-chars
# ADMIN_SEED_DISPLAY_NAME=Owner
