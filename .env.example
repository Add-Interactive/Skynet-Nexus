# --- Skynet Nexus environment ---
# Copy this file to .env for local dev. Do NOT commit .env.

# Port the server listens on locally. Railway ignores this (they inject PORT).
PORT=4180

# Session cookie signing secret. Generate a random 64-char hex string:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-to-a-random-64-char-hex-string

# Where SQLite lives. Defaults to server/skynet.db when unset.
# On Railway, mount a Volume at /data and set DB_PATH=/data/skynet.db.
# DB_PATH=/data/skynet.db

# NODE_ENV=production toggles secure cookies + longer static cache.
# Railway sets this automatically. Leave it unset locally.
# NODE_ENV=production

# Brave Search API key — used by newsroom correspondents.
# Free tier: https://api-dashboard.search.brave.com
BRAVE_API_KEY=your-brave-api-key

# --- Admin account seed (idempotent on every boot) ---
# On startup the server ensures this user exists and has role='admin'. If these
# are left unset, the server falls back to the built-in owner account
# (ageofai2024@gmail.com). Override here or in Railway's variables to change the
# owner login. The seed password is only (re)applied while the account has never
# been logged into, so you can safely change it from the portal afterwards.
ADMIN_SEED_EMAIL=ageofai2024@gmail.com
ADMIN_SEED_PASSWORD=change-me-min-8-chars
ADMIN_SEED_DISPLAY_NAME=Age of AI
